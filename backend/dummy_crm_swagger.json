{
  "openapi": "3.0.0",
  "info": {
    "title": "Dummy CRM API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/crm/users": {
      "post": {
        "summary": "Create a new CRM user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "user_id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  }
                },
                "required": ["user_id"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created"
          }
        }
      }
    },
    "/api/crm/users/{user_id}": {
      "delete": {
        "summary": "Delete an existing CRM user",
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted"
          }
        }
      }
    }
  }
}
